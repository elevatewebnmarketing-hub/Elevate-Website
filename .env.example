# Resend API key (create at https://resend.com/api-keys)
RESEND_API_KEY=re_xxx
# Optional: from address (default: onboarding@resend.dev). Use your verified domain
# RESEND_FROM_EMAIL=hello@elevatewebandmarketing.com
# Optional: fallback NGN/USD rate if exchange API fails (e.g. 1600)
# EXCHANGE_RATE_FALLBACK=1600

# === Required for production (Vercel) ===
# Admin dashboard - use strong values, never commit these
ADMIN_PASSWORD=your-secure-admin-password
SESSION_SECRET=your-random-session-secret-at-least-32-chars

# === Supabase (required for production - blog/testimonials/portfolio editing) ===
# Create project at https://supabase.com/dashboard
# Run supabase/schema.sql in SQL Editor
# Run: npm run db:seed (once) to migrate data from data/*.json
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
